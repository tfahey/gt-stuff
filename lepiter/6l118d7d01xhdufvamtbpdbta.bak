				"code" : "result := OrderedCollection new.\rfound := false.\n\nfileReference readStreamDo: [ :stream |\n    [ stream atEnd ] whileFalse: [ \n\n        | currentLine |\n        currentLine := stream nextLine.\n        \n        found ifTrue: [ \n            result add: currentLine.\r            result size = 2 ifTrue: [ ^result ] \"Stop after 2 lines\"\n        ].\n        \n        (currentLine includesSubstring: targetText) ifTrue: [ \n            found := true \n        ].\n    ]\n]."
			},
